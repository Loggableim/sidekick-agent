# Canonical Sidekick home
# SIDEKICK_HOME=~/.sidekick

# Legacy compatibility alias still read during migration
# HERMES_HOME=~/.hermes

# WebUI runtime
# SIDEKICK_WEBUI_HOST=127.0.0.1
# SIDEKICK_WEBUI_PORT=8787
# SIDEKICK_WEBUI_STATE_DIR=~/.sidekick/state/webui
# SIDEKICK_WEBUI_AGENT_DIR=/path/to/sidekick-agent
# SIDEKICK_WEBUI_PYTHON=/path/to/python
